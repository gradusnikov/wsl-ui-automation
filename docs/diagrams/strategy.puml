@startuml strategy
!theme plain
skinparam backgroundColor #1a1a2e
skinparam defaultFontColor #e0e0e0
skinparam activityBackgroundColor #16213e
skinparam activityBorderColor #0f3460
skinparam activityDiamondBackgroundColor #533483
skinparam activityDiamondBorderColor #0f3460
skinparam arrowColor #e94560
skinparam titleFontColor #e94560

title UI Element Targeting Strategy\nFrom Intelligent to Surgical

start

:Identify what to click;

if (Can describe it in **natural language**?) then (yes)
  #e94560:**Level 1: smart_click** ★
  Hybrid OCR + LLM, ~2s
  Most accurate (82.5% text, 40% icon);
  :smart_click "Submit" -t app
  smart_click "settings icon" -t app;
  stop
else (no)
endif

if (Know the **exact text label**?) then (yes)
  #00b894:**Level 2: click_text**
  Pure OCR, ~2s
  No API cost;
  :click_text "Submit" -t app;
  stop
else (no)
endif

if (Is a **known object class**?) then (yes)
  #0984e3:**Level 4: detect (YOLO)**
  Object detection, ~15ms
  Open vocabulary;
  :detect -t app "button";
  stop
else (no)
endif

if (Need to see **all elements**?) then (yes)
  #6c5ce7:**Level 5: som mark**
  OCR + numbered markers
  Pick by ID;
  :som mark -t app
  som click 17 -t app;
  stop
else (no)
endif

if (Can identify **approximate area**?) then (yes)
  #fdcb6e:**Level 6: gridzoom**
  Hierarchical grid
  Zoom + SAM refine;
  :gridzoom capture -t app
  gridzoom zoom D4
  gridzoom click B5 -t app;
  stop
else (no)
endif

#e17055:**gridzoom refine (SAM)**
Segment Anything Model
Exact object centroid;
:gridzoom refine B5 -t app;
stop

@enduml
