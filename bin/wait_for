#!/usr/bin/env python3
"""Wait until text appears (or disappears) on screen.

Usage:
  wait_for "Loading complete"                Wait for text on screen
  wait_for "Loading complete" -t chrome      Wait for text in Chrome window
  wait_for "Loading..." --gone               Wait until text disappears
  wait_for "Submit" --timeout 30             Custom timeout (default: 15s)
  wait_for "Submit" --interval 0.5           Custom poll interval (default: 1s)

Exit codes: 0 = condition met, 1 = timeout, 2 = error
"""
import sys
import os
import json
import time
import argparse
import subprocess
import urllib.request

SERVER_URL = "http://127.0.0.1:18200"
SCREENSHOT_BIN = os.path.expanduser("~/bin/screenshot")


def server_is_running():
    try:
        req = urllib.request.Request(f"{SERVER_URL}/health", method="GET")
        resp = urllib.request.urlopen(req, timeout=1)
        return resp.status == 200
    except Exception:
        return False


def ocr_via_server(image_path):
    with open(image_path, "rb") as f:
        data = f.read()
    req = urllib.request.Request(
        f"{SERVER_URL}/ocr",
        data=data,
        headers={"Content-Type": "application/octet-stream"},
        method="POST",
    )
    resp = urllib.request.urlopen(req, timeout=30)
    return json.loads(resp.read().decode())


def ocr_direct(image_path):
    import cv2
    import easyocr

    reader = easyocr.Reader(["pl", "en"], gpu=True, verbose=False)
    image = cv2.imread(image_path)
    results = reader.readtext(image)

    regions = []
    for bbox, text, conf in results:
        xs = [int(p[0]) for p in bbox]
        ys = [int(p[1]) for p in bbox]
        x1, y1 = min(xs), min(ys)
        x2, y2 = max(xs), max(ys)
        regions.append({
            "text": text,
            "confidence": round(float(conf), 3),
            "center": [(x1 + x2) // 2, (y1 + y2) // 2],
        })
    return regions


def text_present(query, regions):
    q = query.lower()
    for r in regions:
        t = r["text"].lower()
        if q == t or q in t:
            return r
    # Word-level match
    qwords = q.split()
    if len(qwords) > 1:
        for r in regions:
            t = r["text"].lower()
            twords = t.split()
            if all(any(qw in tw for tw in twords) for qw in qwords):
                return r
    return None


def capture_and_ocr(title, use_server):
    image_path = "/tmp/_wait_for_capture.png"
    cmd = [SCREENSHOT_BIN, image_path]
    if title:
        cmd += ["--title", title]
    subprocess.run(cmd, check=True, capture_output=True)

    if use_server:
        return ocr_via_server(image_path)
    else:
        return ocr_direct(image_path)


def main():
    parser = argparse.ArgumentParser(description="Wait for text on screen")
    parser.add_argument("query", help="Text to wait for")
    parser.add_argument("-t", "--title", help="Target window title/process")
    parser.add_argument("--gone", action="store_true", help="Wait for text to disappear")
    parser.add_argument("--timeout", type=float, default=15, help="Timeout in seconds (default: 15)")
    parser.add_argument("--interval", type=float, default=1, help="Poll interval in seconds (default: 1)")
    args = parser.parse_args()

    use_server = server_is_running()
    start = time.time()

    while True:
        elapsed = time.time() - start
        if elapsed > args.timeout:
            action = "disappear" if args.gone else "appear"
            print(f"Timeout ({args.timeout}s): \"{args.query}\" did not {action}", file=sys.stderr)
            sys.exit(1)

        regions = capture_and_ocr(args.title, use_server)
        match = text_present(args.query, regions)

        if args.gone:
            if match is None:
                print(f"Gone after {elapsed:.1f}s: \"{args.query}\"", file=sys.stderr)
                return
        else:
            if match is not None:
                cx, cy = match["center"]
                print(f"{cx},{cy}  \"{match['text']}\"  ({elapsed:.1f}s)", file=sys.stderr)
                # Print coords to stdout for piping
                print(f"{cx},{cy}")
                return

        time.sleep(args.interval)


if __name__ == "__main__":
    main()
