#!/usr/bin/env python3
"""Find text on screen or in an image. Returns coordinates for clicking.

Usage:
  find_text "search text"                    Search in active screen
  find_text "search text" --title chrome     Search in a specific window
  find_text "search text" --file image.png   Search in an image file
  find_text --list [--title T] [--file F]    List all detected text
  find_text --start                          Start persistent OCR server
  find_text --stop                           Stop persistent OCR server
  find_text --status                         Check server status

Options:
  -t, --title PATTERN    Capture window matching pattern
  -f, --file PATH        Use existing image file instead of capturing
  -l, --list             List all detected text regions
  -i, --case-sensitive   Case-sensitive matching (default: case-insensitive)
  -a, --all              Show all matches (default: best match only)
  -j, --json             Output as JSON
  -v, --vis [PATH]       Save annotated image (default: /tmp/find_text_vis.png)
"""
import sys
import os
import json
import time
import argparse
import subprocess
import urllib.request

SERVER_URL = "http://127.0.0.1:18200"
PID_FILE = "/tmp/ocr_server.pid"
SCREENSHOT_BIN = os.path.expanduser("~/bin/screenshot")


def server_is_running():
    try:
        req = urllib.request.Request(f"{SERVER_URL}/health", method="GET")
        resp = urllib.request.urlopen(req, timeout=1)
        return resp.status == 200
    except Exception:
        return False


def ocr_via_server(image_path):
    with open(image_path, "rb") as f:
        data = f.read()
    req = urllib.request.Request(
        f"{SERVER_URL}/ocr",
        data=data,
        headers={"Content-Type": "application/octet-stream"},
        method="POST",
    )
    resp = urllib.request.urlopen(req, timeout=30)
    return json.loads(resp.read().decode())


def ocr_direct(image_path):
    import cv2
    import easyocr

    print("No server running. Direct OCR...", file=sys.stderr)
    reader = easyocr.Reader(["pl", "en"], gpu=True, verbose=False)
    image = cv2.imread(image_path)
    results = reader.readtext(image)

    regions = []
    for bbox, text, conf in results:
        xs = [int(p[0]) for p in bbox]
        ys = [int(p[1]) for p in bbox]
        x1, y1 = min(xs), min(ys)
        x2, y2 = max(xs), max(ys)
        regions.append({
            "text": text,
            "confidence": round(float(conf), 3),
            "bbox": [x1, y1, x2 - x1, y2 - y1],
            "center": [(x1 + x2) // 2, (y1 + y2) // 2],
        })
    return regions


def capture_screenshot(title=None):
    tmp = "/tmp/_find_text_capture.png"
    cmd = [SCREENSHOT_BIN, tmp]
    if title:
        cmd += ["--title", title]
    subprocess.run(cmd, check=True, capture_output=True)
    return tmp


def start_server():
    print("Starting OCR server...", file=sys.stderr)
    subprocess.Popen(
        [sys.executable, os.path.expanduser("~/bin/ocr_server.py")],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    for _ in range(120):
        time.sleep(0.5)
        if server_is_running():
            print("Server ready.", file=sys.stderr)
            return True
    print("Server failed to start.", file=sys.stderr)
    return False


def stop_server():
    if os.path.exists(PID_FILE):
        with open(PID_FILE) as f:
            pid = int(f.read().strip())
        try:
            os.kill(pid, 15)
            print(f"Stopped OCR server (pid {pid})", file=sys.stderr)
        except ProcessLookupError:
            os.remove(PID_FILE)
            print("Stale pid file removed.", file=sys.stderr)
    else:
        print("No server running.", file=sys.stderr)


def fuzzy_match(query, text, case_sensitive=False):
    """Check if query appears in text. Returns match score (0-1) or 0 if no match."""
    if not case_sensitive:
        query = query.lower()
        text = text.lower()

    if query == text:
        return 1.0
    if query in text:
        return 0.9 * (len(query) / len(text))

    # Word-level: all query words present in text
    qwords = query.split()
    twords = text.split()
    if all(any(qw in tw for tw in twords) for qw in qwords):
        return 0.7

    return 0.0


def _visualize_regions(image_path, regions, vis_path, matches=None):
    import cv2
    img = cv2.imread(image_path)
    match_texts = {m["text"] for m in matches} if matches else set()
    for r in regions:
        x, y, w, h = r["bbox"]
        is_match = r["text"] in match_texts
        color = (0, 255, 0) if is_match else (180, 180, 180)
        thickness = 2 if is_match else 1
        cv2.rectangle(img, (x, y), (x+w, y+h), color, thickness)
        label = r["text"]
        if len(label) > 30:
            label = label[:27] + "..."
        (tw, th), _ = cv2.getTextSize(label, cv2.FONT_HERSHEY_SIMPLEX, 0.4, 1)
        cv2.rectangle(img, (x, y-th-6), (x+tw+4, y), color, -1)
        cv2.putText(img, label, (x+2, y-4), cv2.FONT_HERSHEY_SIMPLEX, 0.4, (0,0,0), 1)
    cv2.imwrite(vis_path, img)
    print(f"Saved: {vis_path}", file=sys.stderr)


def main():
    parser = argparse.ArgumentParser(description="Find text on screen")
    parser.add_argument("query", nargs="?", help="Text to search for")
    parser.add_argument("-t", "--title", help="Window title/process to capture")
    parser.add_argument("-f", "--file", help="Image file to search in")
    parser.add_argument("-l", "--list", action="store_true", help="List all text")
    parser.add_argument("-i", "--case-sensitive", action="store_true")
    parser.add_argument("-a", "--all", action="store_true", help="Show all matches")
    parser.add_argument("-j", "--json", action="store_true", help="JSON output")
    parser.add_argument("-v", "--vis", nargs="?", const="/tmp/find_text_vis.png", help="Save annotated image")
    parser.add_argument("--start", action="store_true", help="Start OCR server")
    parser.add_argument("--stop", action="store_true", help="Stop OCR server")
    parser.add_argument("--status", action="store_true", help="Check server status")
    args = parser.parse_args()

    if args.start:
        if server_is_running():
            print("Server already running.", file=sys.stderr)
        else:
            start_server()
        return

    if args.stop:
        stop_server()
        return

    if args.status:
        status = "running" if server_is_running() else "not running"
        print(f"OCR server is {status}.", file=sys.stderr)
        return

    if not args.query and not args.list:
        parser.print_help()
        sys.exit(1)

    # Get image
    if args.file:
        image_path = args.file
    else:
        image_path = capture_screenshot(args.title)

    # Run OCR
    t0 = time.time()
    if server_is_running():
        regions = ocr_via_server(image_path)
    else:
        regions = ocr_direct(image_path)
    elapsed = time.time() - t0

    if args.list:
        if args.vis:
            _visualize_regions(image_path, regions, args.vis)
        if args.json:
            print(json.dumps(regions, indent=2, ensure_ascii=False))
        else:
            for r in regions:
                cx, cy = r["center"]
                print(f"  ({cx:4d},{cy:4d})  {r['confidence']:.2f}  \"{r['text']}\"")
            print(f"\n{len(regions)} regions in {elapsed:.2f}s", file=sys.stderr)
        return

    # Search for query
    matches = []
    for r in regions:
        score = fuzzy_match(args.query, r["text"], args.case_sensitive)
        if score > 0:
            matches.append({**r, "score": score})

    matches.sort(key=lambda m: m["score"], reverse=True)

    if not matches:
        print(f"Not found: \"{args.query}\"", file=sys.stderr)
        print(f"(scanned {len(regions)} text regions in {elapsed:.2f}s)", file=sys.stderr)
        sys.exit(1)

    if not args.all:
        matches = matches[:1]

    if args.vis:
        _visualize_regions(image_path, regions, args.vis, matches)

    if args.json:
        print(json.dumps(matches, indent=2, ensure_ascii=False))
    else:
        for m in matches:
            cx, cy = m["center"]
            x, y, w, h = m["bbox"]
            print(f"{cx},{cy}  \"{m['text']}\"  bbox=[{x},{y},{w},{h}]  conf={m['confidence']}")
        print(f"({elapsed:.2f}s)", file=sys.stderr)


if __name__ == "__main__":
    main()
