#!/bin/bash

# Defaults
FILENAME=""
HIDE_WINDOW=false
SCREEN_INDEX=""
DELAY=0
REGION=""
CAPTURE_WINDOW=false
CAPTURE_CLIPBOARD=false
CAPTURE_ALL=false
SCALE=""
OPEN_AFTER=false
TITLE=""
CROP=""
ANNOTATIONS=()
GRID=0
CHESS=""

# Parse arguments — first positional arg (not starting with -) is the filename
while [[ $# -gt 0 ]]; do
  case "$1" in
    --arrow)
      ANNOTATIONS+=("arrow:$2")
      shift 2
      ;;
    --circle)
      ANNOTATIONS+=("circle:$2")
      shift 2
      ;;
    --highlight)
      ANNOTATIONS+=("highlight:$2")
      shift 2
      ;;
    --label)
      ANNOTATIONS+=("label:$2:$3")
      shift 3
      ;;
    --color)
      ANNOTATIONS+=("color:$2")
      shift 2
      ;;
    --grid)
      GRID="${2:-100}"
      shift 2
      ;;
    --chess)
      CHESS="${2:-8}"
      shift 2
      ;;
    --hide|-h)
      HIDE_WINDOW=true
      shift
      ;;
    --screen|-s)
      SCREEN_INDEX="$2"
      shift 2
      ;;
    --delay|-d)
      DELAY="$2"
      shift 2
      ;;
    --region|-r)
      REGION="$2"
      shift 2
      ;;
    --window|-w)
      CAPTURE_WINDOW=true
      shift
      ;;
    --clipboard|-c)
      CAPTURE_CLIPBOARD=true
      shift
      ;;
    --all|-a)
      CAPTURE_ALL=true
      shift
      ;;
    --title|-t)
      TITLE="$2"
      shift 2
      ;;
    --crop)
      CROP="$2"
      shift 2
      ;;
    --scale)
      SCALE="$2"
      shift 2
      ;;
    --open|-o)
      OPEN_AFTER=true
      shift
      ;;
    --list|-l)
      powershell.exe -Command "
Add-Type -AssemblyName System.Windows.Forms;
\$screens = [System.Windows.Forms.Screen]::AllScreens;
for (\$i = 0; \$i -lt \$screens.Length; \$i++) {
  \$s = \$screens[\$i];
  \$p = if (\$s.Primary) { ' (primary)' } else { '' };
  Write-Host \"[\$i] \$(\$s.DeviceName)\$p - \$(\$s.Bounds.Width)x\$(\$s.Bounds.Height) at (\$(\$s.Bounds.X),\$(\$s.Bounds.Y))\"
}"
      exit 0
      ;;
    --help)
      cat <<'HELP'
Usage: screenshot [FILENAME] [OPTIONS]

Captures screen content on WSL/Windows.
Default filename: /tmp/screenshot.png

Capture modes (mutually exclusive):
  --screen N, -s N    Capture screen N (use --list to see screens)
  --window, -w        Capture the active/focused window
  --title P, -t P     Capture window matching title/process P (no focus needed)
  --crop X,Y,W,H      Crop the result to a rectangle (applied after capture)
  --region X,Y,W,H    Capture a specific rectangle (-r 100,200,800,600)
  --clipboard, -c     Save clipboard image to file
  --all, -a           Capture all monitors stitched into one image

Options:
  --hide, -h          Hide the terminal window before capturing
  --delay N, -d N     Wait N seconds before capturing
  --scale N           Downscale by percentage (e.g. --scale 50)
  --open, -o          Open the image after saving
  --list, -l          List available screens
  --help              Show this help

Annotations (can be repeated, drawn in order):
  --arrow X1,Y1,X2,Y2       Draw arrow from (X1,Y1) to (X2,Y2)
  --circle X,Y,R             Draw circle at (X,Y) with radius R
  --highlight X,Y,W,H        Semi-transparent highlight rectangle
  --label X,Y "text"         Text label at (X,Y)
  --color NAME               Set color for subsequent annotations (red,green,blue,yellow,cyan,white)
  --grid [N]                 Draw coordinate grid with N pixel spacing (default 100)
  --chess [N]                Chess-coordinate grid with NxN cells (default 8). Prints cell centers.
HELP
      exit 0
      ;;
    -*)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
    *)
      if [ -z "$FILENAME" ]; then
        FILENAME="$1"
      fi
      shift
      ;;
  esac
done

# Default filename to /tmp/screenshot.png
if [ -z "$FILENAME" ]; then
  FILENAME="/tmp/screenshot.png"
fi

# Resolve to Windows path
if [[ "$FILENAME" = /* ]]; then
  WIN_PATH="$(wslpath -w "$FILENAME")"
else
  WIN_PATH="$(wslpath -w "$(pwd)/${FILENAME}")"
fi

# --- Build PowerShell command ---

PS_CMD='Add-Type -AssemblyName System.Windows.Forms,System.Drawing;'

# Win32 helpers for hide, active window, and title-based capture
if [ "$HIDE_WINDOW" = true ] || [ "$CAPTURE_WINDOW" = true ] || [ -n "$TITLE" ]; then
  PS_CMD+='
Add-Type @"
using System;
using System.Runtime.InteropServices;
using System.Text;
using System.Collections.Generic;
public class Win32 {
  public delegate bool EnumWindowsProc(IntPtr hWnd, IntPtr lParam);
  [DllImport("user32.dll")] public static extern bool ShowWindow(IntPtr hWnd, int nCmdShow);
  [DllImport("user32.dll")] public static extern IntPtr GetForegroundWindow();
  [DllImport("user32.dll")] public static extern bool GetWindowRect(IntPtr hWnd, out RECT lpRect);
  [DllImport("user32.dll")] public static extern bool EnumWindows(EnumWindowsProc lpEnumFunc, IntPtr lParam);
  [DllImport("user32.dll")] public static extern int GetWindowTextLength(IntPtr hWnd);
  [DllImport("user32.dll")] public static extern int GetWindowText(IntPtr hWnd, StringBuilder lpString, int nMaxCount);
  [DllImport("user32.dll")] public static extern bool IsWindowVisible(IntPtr hWnd);
  [DllImport("user32.dll")] public static extern uint GetWindowThreadProcessId(IntPtr hWnd, out uint lpdwProcessId);
  [DllImport("user32.dll")] public static extern bool PrintWindow(IntPtr hWnd, IntPtr hdcBlt, uint nFlags);
  [StructLayout(LayoutKind.Sequential)] public struct RECT { public int Left, Top, Right, Bottom; }
}
"@;'
fi

# Hide terminal
if [ "$HIDE_WINDOW" = true ]; then
  PS_CMD+='
$procs = Get-Process | Where-Object { $_.MainWindowHandle -ne 0 };
$wt = $procs | Where-Object { $_.ProcessName -eq "WindowsTerminal" } | Select-Object -First 1;
if ($wt) { $hwnd_term = $wt.MainWindowHandle } else {
  $wt = $procs | Where-Object { $_.ProcessName -match "cmd|powershell|conhost" } | Select-Object -First 1;
  $hwnd_term = $wt.MainWindowHandle;
};
[Win32]::ShowWindow($hwnd_term, 0) | Out-Null;
Start-Sleep -Milliseconds 300;'
fi

# Delay
if [ "$DELAY" -gt 0 ] 2>/dev/null; then
  PS_CMD+="
Start-Sleep -Seconds ${DELAY};"
fi

# Capture mode
if [ -n "$TITLE" ]; then
  PS_CMD+="
\$pattern = '${TITLE}'.ToLower();
\$targetHwnd = [IntPtr]::Zero;
\$windows = New-Object System.Collections.ArrayList;
[Win32]::EnumWindows({
  param(\$h, \$l)
  if ([Win32]::IsWindowVisible(\$h)) {
    \$len = [Win32]::GetWindowTextLength(\$h);
    if (\$len -gt 0) { \$windows.Add(\$h) | Out-Null }
  }
  return \$true
}, [IntPtr]::Zero) | Out-Null;
foreach (\$w in \$windows) {
  \$len = [Win32]::GetWindowTextLength(\$w);
  \$sb = New-Object System.Text.StringBuilder (\$len + 1);
  [Win32]::GetWindowText(\$w, \$sb, \$sb.Capacity) | Out-Null;
  \$wtitle = \$sb.ToString().ToLower();
  \$wpid = [uint32]0;
  [Win32]::GetWindowThreadProcessId(\$w, [ref]\$wpid) | Out-Null;
  \$proc = '';
  try { \$proc = (Get-Process -Id \$wpid -ErrorAction SilentlyContinue).ProcessName.ToLower() } catch {};
  if (\$wtitle.Contains(\$pattern) -or \$proc.Contains(\$pattern)) {
    \$targetHwnd = \$w; break;
  }
}
if (\$targetHwnd -eq [IntPtr]::Zero) { Write-Error 'No window found matching: ${TITLE}'; exit 1 };
\$rect = New-Object Win32+RECT;
[Win32]::GetWindowRect(\$targetHwnd, [ref]\$rect) | Out-Null;
\$tw = \$rect.Right - \$rect.Left;
\$th = \$rect.Bottom - \$rect.Top;
\$b = New-Object System.Drawing.Bitmap \$tw,\$th;
\$g = [System.Drawing.Graphics]::FromImage(\$b);
\$hdc = \$g.GetHdc();
[Win32]::PrintWindow(\$targetHwnd, \$hdc, 2) | Out-Null;
\$g.ReleaseHdc(\$hdc);"

elif [ "$CAPTURE_CLIPBOARD" = true ]; then
  PS_CMD+='
$img = [System.Windows.Forms.Clipboard]::GetImage();
if ($img -eq $null) { Write-Error "No image on clipboard"; exit 1 };
$b = New-Object System.Drawing.Bitmap $img;'

elif [ "$CAPTURE_WINDOW" = true ]; then
  PS_CMD+='
$hwnd_fg = [Win32]::GetForegroundWindow();
$rect = New-Object Win32+RECT;
[Win32]::GetWindowRect($hwnd_fg, [ref]$rect) | Out-Null;
$w = $rect.Right - $rect.Left;
$h = $rect.Bottom - $rect.Top;
$b = New-Object System.Drawing.Bitmap $w,$h;
$g = [System.Drawing.Graphics]::FromImage($b);
$g.CopyFromScreen($rect.Left, $rect.Top, 0, 0, (New-Object System.Drawing.Size $w,$h));'

elif [ -n "$REGION" ]; then
  IFS=',' read -r RX RY RW RH <<< "$REGION"
  PS_CMD+="
\$b = New-Object System.Drawing.Bitmap ${RW},${RH};
\$g = [System.Drawing.Graphics]::FromImage(\$b);
\$g.CopyFromScreen(${RX}, ${RY}, 0, 0, (New-Object System.Drawing.Size ${RW},${RH}));"

elif [ "$CAPTURE_ALL" = true ]; then
  PS_CMD+='
$allBounds = [System.Windows.Forms.SystemInformation]::VirtualScreen;
$b = New-Object System.Drawing.Bitmap $allBounds.Width,$allBounds.Height;
$g = [System.Drawing.Graphics]::FromImage($b);
$g.CopyFromScreen($allBounds.Location, [System.Drawing.Point]::Empty, $allBounds.Size);'

elif [ -n "$SCREEN_INDEX" ]; then
  PS_CMD+="
\$s = [System.Windows.Forms.Screen]::AllScreens[${SCREEN_INDEX}].Bounds;
\$b = New-Object System.Drawing.Bitmap \$s.Width,\$s.Height;
\$g = [System.Drawing.Graphics]::FromImage(\$b);
\$g.CopyFromScreen(\$s.Location, [System.Drawing.Point]::Empty, \$s.Size);"

else
  PS_CMD+='
$s = [System.Windows.Forms.Screen]::PrimaryScreen.Bounds;
$b = New-Object System.Drawing.Bitmap $s.Width,$s.Height;
$g = [System.Drawing.Graphics]::FromImage($b);
$g.CopyFromScreen($s.Location, [System.Drawing.Point]::Empty, $s.Size);'
fi

# Scale
if [ -n "$SCALE" ]; then
  PS_CMD+="
\$newW = [int](\$b.Width * ${SCALE} / 100);
\$newH = [int](\$b.Height * ${SCALE} / 100);
\$scaled = New-Object System.Drawing.Bitmap \$newW,\$newH;
\$gs = [System.Drawing.Graphics]::FromImage(\$scaled);
\$gs.InterpolationMode = [System.Drawing.Drawing2D.InterpolationMode]::HighQualityBicubic;
\$gs.DrawImage(\$b, 0, 0, \$newW, \$newH);
\$gs.Dispose();
\$b.Dispose();
\$b = \$scaled;"
fi

# Crop
if [ -n "$CROP" ]; then
  IFS=',' read -r CX CY CW CH <<< "$CROP"
  PS_CMD+="
\$cropped = New-Object System.Drawing.Bitmap ${CW},${CH};
\$gc = [System.Drawing.Graphics]::FromImage(\$cropped);
\$gc.DrawImage(\$b, 0, 0, (New-Object System.Drawing.Rectangle ${CX},${CY},${CW},${CH}), [System.Drawing.GraphicsUnit]::Pixel);
\$gc.Dispose();
\$b.Dispose();
\$b = \$cropped;"
fi

# Annotations
if [ ${#ANNOTATIONS[@]} -gt 0 ]; then
  PS_CMD+='
$ag = [System.Drawing.Graphics]::FromImage($b);
$ag.SmoothingMode = [System.Drawing.Drawing2D.SmoothingMode]::AntiAlias;
$ag.TextRenderingHint = [System.Drawing.Text.TextRenderingHint]::AntiAlias;
$acolor = [System.Drawing.Color]::Red;'

  for ann in "${ANNOTATIONS[@]}"; do
    TYPE="${ann%%:*}"
    DATA="${ann#*:}"

    case "$TYPE" in
      color)
        case "${DATA,,}" in
          red)    PS_CMD+='$acolor = [System.Drawing.Color]::Red;' ;;
          green)  PS_CMD+='$acolor = [System.Drawing.Color]::Lime;' ;;
          blue)   PS_CMD+='$acolor = [System.Drawing.Color]::DodgerBlue;' ;;
          yellow) PS_CMD+='$acolor = [System.Drawing.Color]::Yellow;' ;;
          cyan)   PS_CMD+='$acolor = [System.Drawing.Color]::Cyan;' ;;
          white)  PS_CMD+='$acolor = [System.Drawing.Color]::White;' ;;
          *)      PS_CMD+='$acolor = [System.Drawing.Color]::Red;' ;;
        esac
        ;;
      arrow)
        IFS=',' read -r AX1 AY1 AX2 AY2 <<< "$DATA"
        PS_CMD+="
\$apen = New-Object System.Drawing.Pen(\$acolor, 3);
\$apen.EndCap = [System.Drawing.Drawing2D.LineCap]::ArrowAnchor;
\$apen.CustomEndCap = New-Object System.Drawing.Drawing2D.AdjustableArrowCap(8, 6, \$true);
\$ag.DrawLine(\$apen, ${AX1}, ${AY1}, ${AX2}, ${AY2});
\$apen.Dispose();"
        ;;
      circle)
        IFS=',' read -r CRX CRY CRR <<< "$DATA"
        PS_CMD+="
\$apen = New-Object System.Drawing.Pen(\$acolor, 3);
\$ag.DrawEllipse(\$apen, $((CRX - CRR)), $((CRY - CRR)), $((CRR * 2)), $((CRR * 2)));
\$apen.Dispose();"
        ;;
      highlight)
        IFS=',' read -r HX HY HW HH <<< "$DATA"
        PS_CMD+="
\$hbrush = New-Object System.Drawing.SolidBrush([System.Drawing.Color]::FromArgb(80, \$acolor));
\$ag.FillRectangle(\$hbrush, ${HX}, ${HY}, ${HW}, ${HH});
\$hbrush.Dispose();
\$apen = New-Object System.Drawing.Pen(\$acolor, 2);
\$ag.DrawRectangle(\$apen, ${HX}, ${HY}, ${HW}, ${HH});
\$apen.Dispose();"
        ;;
      label)
        # DATA is "X,Y:text"
        COORDS="${DATA%%:*}"
        LTEXT="${DATA#*:}"
        IFS=',' read -r LX LY <<< "$COORDS"
        # Escape single quotes for PowerShell
        LTEXT="${LTEXT//\'/\'\'}"
        PS_CMD+="
\$afont = New-Object System.Drawing.Font('Segoe UI', 16, [System.Drawing.FontStyle]::Bold);
\$apath = New-Object System.Drawing.Drawing2D.GraphicsPath;
\$apath.AddString('${LTEXT}', \$afont.FontFamily, [int]\$afont.Style, 22, (New-Object System.Drawing.Point(${LX}, ${LY})), [System.Drawing.StringFormat]::GenericDefault);
\$ag.DrawPath((New-Object System.Drawing.Pen([System.Drawing.Color]::FromArgb(200, 0, 0, 0), 4)), \$apath);
\$ag.FillPath((New-Object System.Drawing.SolidBrush(\$acolor)), \$apath);
\$afont.Dispose();
\$apath.Dispose();"
        ;;
    esac
  done

  PS_CMD+='
$ag.Dispose();'
fi

# Grid overlay
if [ "$GRID" -gt 0 ] 2>/dev/null; then
  PS_CMD+="
\$gg = [System.Drawing.Graphics]::FromImage(\$b);
\$gg.SmoothingMode = [System.Drawing.Drawing2D.SmoothingMode]::AntiAlias;
\$gg.TextRenderingHint = [System.Drawing.Text.TextRenderingHint]::AntiAlias;
\$gpen = New-Object System.Drawing.Pen([System.Drawing.Color]::FromArgb(100, 255, 0, 255), 1);
\$gfont = New-Object System.Drawing.Font('Consolas', 9);
\$gbg = New-Object System.Drawing.SolidBrush([System.Drawing.Color]::FromArgb(180, 0, 0, 0));
\$gfg = New-Object System.Drawing.SolidBrush([System.Drawing.Color]::FromArgb(220, 255, 0, 255));
\$spacing = ${GRID};
\$offX = ${CROP:+${CROP%%,*}}${CROP:-0}; \$offY = 0;
$(if [ -n "$CROP" ]; then
  IFS=',' read -r _GCX _GCY _GCW _GCH <<< "$CROP"
  echo "\$offX = ${_GCX}; \$offY = ${_GCY};"
else
  echo '$offX = 0; $offY = 0;'
fi)
\$startX = \$spacing - (\$offX % \$spacing); if (\$startX -eq \$spacing) { \$startX = 0 };
\$startY = \$spacing - (\$offY % \$spacing); if (\$startY -eq \$spacing) { \$startY = 0 };
for (\$gx = \$startX; \$gx -lt \$b.Width; \$gx += \$spacing) {
  \$gg.DrawLine(\$gpen, \$gx, 0, \$gx, \$b.Height);
  \$lbl = (\$gx + \$offX).ToString();
  \$sz = \$gg.MeasureString(\$lbl, \$gfont);
  \$gg.FillRectangle(\$gbg, \$gx + 2, 1, \$sz.Width, \$sz.Height);
  \$gg.DrawString(\$lbl, \$gfont, \$gfg, (\$gx + 2), 1);
}
for (\$gy = \$startY; \$gy -lt \$b.Height; \$gy += \$spacing) {
  \$gg.DrawLine(\$gpen, 0, \$gy, \$b.Width, \$gy);
  \$lbl = (\$gy + \$offY).ToString();
  \$sz = \$gg.MeasureString(\$lbl, \$gfont);
  \$gg.FillRectangle(\$gbg, 1, \$gy + 2, \$sz.Width, \$sz.Height);
  \$gg.DrawString(\$lbl, \$gfont, \$gfg, 1, (\$gy + 2));
}
\$gpen.Dispose(); \$gfont.Dispose(); \$gbg.Dispose(); \$gfg.Dispose(); \$gg.Dispose();"
fi

# Chess grid overlay
if [ -n "$CHESS" ] && [ "$CHESS" -gt 0 ] 2>/dev/null; then
  COLS=$CHESS
  ROWS=$CHESS
  PS_CMD+="
\$cg = [System.Drawing.Graphics]::FromImage(\$b);
\$cg.SmoothingMode = [System.Drawing.Drawing2D.SmoothingMode]::AntiAlias;
\$cg.TextRenderingHint = [System.Drawing.Text.TextRenderingHint]::AntiAlias;
\$cpen = New-Object System.Drawing.Pen([System.Drawing.Color]::FromArgb(140, 255, 255, 0), 2);
\$cfont = New-Object System.Drawing.Font('Consolas', 12, [System.Drawing.FontStyle]::Bold);
\$cbg = New-Object System.Drawing.SolidBrush([System.Drawing.Color]::FromArgb(180, 0, 0, 0));
\$cfg = New-Object System.Drawing.SolidBrush([System.Drawing.Color]::FromArgb(240, 255, 255, 0));
\$cols = ${COLS}; \$rows = ${ROWS};
\$cw = [math]::Floor(\$b.Width / \$cols);
\$ch = [math]::Floor(\$b.Height / \$rows);
\$letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
for (\$cx = 1; \$cx -lt \$cols; \$cx++) { \$cg.DrawLine(\$cpen, \$cx * \$cw, 0, \$cx * \$cw, \$b.Height); }
for (\$cy = 1; \$cy -lt \$rows; \$cy++) { \$cg.DrawLine(\$cpen, 0, \$cy * \$ch, \$b.Width, \$cy * \$ch); }
for (\$cy = 0; \$cy -lt \$rows; \$cy++) {
  for (\$cx = 0; \$cx -lt \$cols; \$cx++) {
    \$lbl = \$letters[\$cx].ToString() + (\$cy + 1).ToString();
    \$sz = \$cg.MeasureString(\$lbl, \$cfont);
    \$lx = \$cx * \$cw + (\$cw - \$sz.Width) / 2;
    \$ly = \$cy * \$ch + (\$ch - \$sz.Height) / 2;
    \$cg.FillRectangle(\$cbg, [int]\$lx - 2, [int]\$ly - 1, [int]\$sz.Width + 4, [int]\$sz.Height + 2);
    \$cg.DrawString(\$lbl, \$cfont, \$cfg, [float]\$lx, [float]\$ly);
  }
}
\$cpen.Dispose(); \$cfont.Dispose(); \$cbg.Dispose(); \$cfg.Dispose(); \$cg.Dispose();"

  # Print cell center coordinates to stderr (so they appear even when piped)
  echo "Chess grid: ${COLS}x${ROWS}" >&2
  # We need image dimensions - compute after PS runs, so build a bash lookup table
  CHESS_PRINT=true
fi

# Save
PS_CMD+="
\$b.Save('${WIN_PATH}');"

if [ "${CHESS_PRINT:-false}" = true ]; then
  PS_CMD+="
Write-Output \"IMGSIZE:\$(\$b.Width),\$(\$b.Height)\";"
fi

# Restore terminal
if [ "$HIDE_WINDOW" = true ]; then
  PS_CMD+='
[Win32]::ShowWindow($hwnd_term, 9) | Out-Null;'
fi

# Execute
if [ "${CHESS_PRINT:-false}" = true ]; then
  PS_OUT=$(powershell.exe -Command "$PS_CMD" 2>&1)
  IMG_DIMS=$(echo "$PS_OUT" | grep '^IMGSIZE:' | tr -d '\r')
else
  powershell.exe -Command "$PS_CMD"
fi

echo "Saved: $FILENAME"

# Print chess grid coordinate table
if [ "${CHESS_PRINT:-false}" = true ] && [ -n "$IMG_DIMS" ]; then
  IFS=',' read -r IMG_W IMG_H <<< "${IMG_DIMS#IMGSIZE:}"
  LETTERS="ABCDEFGHIJKLMNOPQRSTUVWXYZ"
  CW=$((IMG_W / COLS))
  CH=$((IMG_H / ROWS))
  for ((row=0; row<ROWS; row++)); do
    for ((col=0; col<COLS; col++)); do
      L=${LETTERS:$col:1}
      R=$((row + 1))
      CX=$((col * CW + CW / 2))
      CY=$((row * CH + CH / 2))
      printf "%s%d=%d,%d  " "$L" "$R" "$CX" "$CY"
    done
    echo
  done
fi

# Open after saving
if [ "$OPEN_AFTER" = true ]; then
  cmd.exe /C start "" "$(wslpath -w "$FILENAME")" 2>/dev/null
fi
